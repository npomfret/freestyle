{
  "name": "freestyle",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "db:tunnel": "./scripts/db-tunnel.sh",
    "deploy": "./scripts/deploy.sh",
    "deploy:build": "docker compose -f docker-compose.production.yml --env-file .env.production build app",
    "deploy:db": "docker compose -f docker-compose.production.yml --env-file .env.production up -d db",
    "deploy:up": "docker compose -f docker-compose.production.yml --env-file .env.production up -d app",
    "deploy:logs": "docker compose -f docker-compose.production.yml --env-file .env.production logs -f app",
    "migrate": "tsx src/migrate.ts",
    "embed": "tsx src/generate-embeddings.ts",
    "re-embed": "tsx src/re-embed-all.ts",
    "search": "tsx src/search.ts",
    "discover": "tsx src/discover.ts",
    "validity-check": "tsx src/recheck.ts",
    "validity-check:suspect": "tsx src/recheck.ts --suspect",
    "repair": "tsx src/repair.ts",
    "repair:no-analysis": "tsx src/repair.ts --mode no-analysis",
    "repair:no-description": "tsx src/repair.ts --mode no-description",
    "add-url": "tsx src/discover.ts",
    "compile": "tsc --noEmit && cd web && tsc --noEmit",
    "server": "NODE_OPTIONS=\"-r dotenv/config\" tsx src/server.ts",
    "dev": "tsx src/dev.ts",
    "dev:web": "cd web && npm run dev",
    "build:web": "cd web && npm run build",
    "format": "node scripts/format.js",
    "gemini-quota": "tsx src/gemini-quota.ts",
    "idea-loop": "./scripts/idea-loop.sh",
    "test": "node --import tsx/esm --test 'src/**/*.test.ts'"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@huggingface/transformers": "^3.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.13.0"
  },
  "optionalDependencies": {
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
