POSTGRES_PASSWORD=freestyle
POSTGRES_PORT=5433
DATABASE_URL=postgresql://freestyle:freestyle@localhost:5433/freestyle

# LLM provider: "gemini-cli" (free via Gemini CLI), "ollama" (local), or "gemini" (paid API)
LLM_PROVIDER=gemini-cli

# Gemini model — used by gemini-cli and gemini providers
GEMINI_MODEL=gemini-2.5-flash-lite

# Model cascade for gemini-cli (comma-separated, cheapest first).
# When a model hits its rate limit, the next one is used automatically.
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.5-pro

# Gemini API key — required for "gemini" provider and web search grounding in discover
GEMINI_API_KEY=...

# Local LLM — used by LLM_PROVIDER=local (OpenAI-compatible: MLX Studio, LM Studio, vllm, etc.)
# LOCAL_LLM_MODEL is optional — for MLX Studio the port determines the model
LOCAL_LLM_MODEL=local
LOCAL_LLM_URL=http://localhost:12336

# Ollama — used by LLM_PROVIDER=ollama (Ollama's native /api/chat format)
# LOCAL_LLM_MODEL=qwen2.5:32b
# LOCAL_LLM_URL=http://localhost:11434
